# MoneyGuard environment configuration.
# Copy to `.env` and fill in real keys for the LIVE path.
# The mock path (`moneyguard --mock`) needs NONE of these.

# --- Credentials (required only for live providers) ---
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# --- Model selection (optional; defaults shown) ---
# Vision / OCR — structured numeric extraction only.
MONEY_GUARD_VISION_MODEL=gemini-2.5-flash
# Copywriting / audit — standard instruct, streamed.
MONEY_GUARD_TEXT_MODEL=deepseek-v4-flash

# --- Provider mode (optional) ---
# Set to "1" or "true" to force the deterministic offline mock providers,
# equivalent to passing `--mock` on the CLI.
MONEYGUARD_MOCK=

# --- Debug (optional) ---
# When "true", logs the de-identified payload sent upstream and extra diagnostics.
# Normal logs carry only safe metadata (period, confidence, tier, model names).
MONEY_GUARD_DEBUG=
